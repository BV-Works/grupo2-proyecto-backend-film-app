<!-- cambia dependiendo de si el usuario está logueado o no, y si es admin o user -->
 <nav class="menu">
  <% if (user) { %>
    <% if (user.role === 'admin') { %>
      <a href="/admin-users">Usuarios</a>
      <a href="/admin-movies">Películas</a>
    <% } else { %>
      <a href="/dashboard">Inicio</a>
      <a href="/favorites">Favoritos</a>
    <% } %>
    <!-- MEJORA: DEBERIAMOS SACAR LA FUNCIONALIDAD DEL LOGOUT A PUBLIC/EVENTS.JS -->
    <form action="/api/logout" method="POST">
  <button type="submit">Cerrar sesión</button>
</form>
  <% } else { %>
    <a href="/login">Login</a>
    <a href="/signup">Registro</a>
  <% } %>
</nav>